{
  "info": {
    "_postman_id": "orbitly-complete-api",
    "name": "Orbitly API - Complete Collection",
    "description": "Complete API collection for Orbitly with all endpoints including Super Admin, Tenant Admin, and Public APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "1. Super Admin Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"your-super-admin-password\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.session && jsonData.session.access_token) {",
                "    pm.environment.set(\"super_admin_token\", jsonData.session.access_token);",
                "    pm.environment.set(\"super_admin_refresh\", jsonData.session.refresh_token);",
                "    console.log(\"✅ Super Admin token saved\");",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "2. Register New User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"userpassword123\",\n  \"full_name\": \"Test User\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"]}
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.user && jsonData.user.id) {",
                "    pm.environment.set(\"new_user_id\", jsonData.user.id);",
                "    console.log(\"✅ New user ID saved: \" + jsonData.user.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "3. Tenant User Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"userpassword123\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.session && jsonData.session.access_token) {",
                "    pm.environment.set(\"tenant_token\", jsonData.session.access_token);",
                "    pm.environment.set(\"tenant_refresh\", jsonData.session.refresh_token);",
                "    console.log(\"✅ Tenant token saved\");",
                "}",
                "if (jsonData.user && jsonData.user.tenant_id) {",
                "    pm.environment.set(\"tenant_id\", jsonData.user.tenant_id);",
                "    console.log(\"✅ Tenant ID saved: \" + jsonData.user.tenant_id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "4. Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{tenant_refresh}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"]}
          }
        },
        {
          "name": "5. Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{tenant_token}}"}],
            "url": {"raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"]}
          }
        },
        {
          "name": "6. Forgot Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth", "forgot-password"]}
          }
        }
      ]
    },
