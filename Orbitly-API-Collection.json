          "name": "Resolve Tenant by Domain",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/public/resolve-tenant?domain=demo.orbitly.com",
              "host": ["{{base_url}}"],
              "path": ["public", "resolve-tenant"],
              "query": [
                {
                  "key": "domain",
                  "value": "demo.orbitly.com"
                }
              ]
            },
            "description": "Get tenant info by domain. Useful for multi-tenant apps."
          }
        }
      ],
      "description": "Public endpoints that don't require authentication"
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://orbitly.onrender.com/api",
      "type": "string"
    }
  ]
}
